#!/usr/bin/env sh
set -eu

repo="${YURU_INSTALL_REPO:-Ameyanagi/yuru}"
version="${YURU_INSTALL_VERSION:-latest}"
bin_dir="${YURU_INSTALL_BIN_DIR:-${XDG_BIN_HOME:-$HOME/.local/bin}}"
default_lang="${YURU_INSTALL_DEFAULT_LANG:-ja}"
bindings="${YURU_INSTALL_BINDINGS:-ask}"
selected_bindings=""
no_config=0
shells=""
from_source=0

usage() {
  cat <<'EOF'
Yuru user-space installer

Usage:
  ./install [options]
  curl -fsSL https://raw.githubusercontent.com/Ameyanagi/yuru/main/install | sh -s -- [options]

Options:
  --all                 Install binary and shell integration for the current shell
  --shell LIST          Install shell integration: bash,zsh,fish,all
  --no-shell            Install only the binary
  --bin-dir DIR         Install binary into DIR (default: ~/.local/bin)
  --repo OWNER/REPO     GitHub repository to download from (default: Ameyanagi/yuru)
  --version TAG         Release tag to download (default: latest)
  --default-lang LANG   Configure default language: ask, plain, ja, zh, auto, none (default: ja)
  --bindings LIST       Shell bindings to enable: ask, all, none, ctrl-t, ctrl-r, alt-c, completion
                        Comma-separated lists are accepted, for example: ctrl-t,ctrl-r
                        (default: ask when shell integration is installed)
  --no-config           Do not create or update the user config file
  --from-source         Build yuru from the current checkout with cargo
  -h, --help            Show this help

This installer defaults to user-space paths and never uses sudo.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --all)
      shells="current"
      shift
      ;;
    --shell)
      shells="${2:-}"
      [ -n "$shells" ] || {
        echo "install: --shell requires a value" >&2
        exit 2
      }
      shift 2
      ;;
    --no-shell)
      shells=""
      shift
      ;;
    --bin-dir)
      bin_dir="${2:-}"
      [ -n "$bin_dir" ] || {
        echo "install: --bin-dir requires a value" >&2
        exit 2
      }
      shift 2
      ;;
    --repo)
      repo="${2:-}"
      [ -n "$repo" ] || {
        echo "install: --repo requires a value" >&2
        exit 2
      }
      shift 2
      ;;
    --version)
      version="${2:-}"
      [ -n "$version" ] || {
        echo "install: --version requires a value" >&2
        exit 2
      }
      shift 2
      ;;
    --default-lang)
      default_lang="${2:-}"
      [ -n "$default_lang" ] || {
        echo "install: --default-lang requires a value" >&2
        exit 2
      }
      shift 2
      ;;
    --bindings)
      bindings="${2:-}"
      [ -n "$bindings" ] || {
        echo "install: --bindings requires a value" >&2
        exit 2
      }
      shift 2
      ;;
    --no-config)
      no_config=1
      shift
      ;;
    --from-source)
      from_source=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "install: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

log() {
  printf 'yuru-install: %s\n' "$*"
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "install: required command not found: $1" >&2
    exit 1
  fi
}

sh_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

fish_quote() {
  printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\$/\\$/g')"
}

config_file() {
  if [ -n "${YURU_CONFIG_FILE:-}" ]; then
    printf '%s' "$YURU_CONFIG_FILE"
  elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
    printf '%s/yuru/config.toml' "$XDG_CONFIG_HOME"
  else
    printf '%s/.config/yuru/config.toml' "$HOME"
  fi
}

validate_default_lang() {
  case "$1" in
    ask | plain | ja | zh | auto | none) ;;
    *)
      echo "install: unsupported default language: $1" >&2
      echo "install: expected one of: ask, plain, ja, zh, auto, none" >&2
      exit 2
      ;;
  esac
}

validate_bindings() {
  case "$1" in
    ask | all | none) return ;;
  esac

  old_ifs="$IFS"
  IFS=','
  for item in $1; do
    IFS="$old_ifs"
    item="$(printf '%s' "$item" | tr -d '[:space:]')"
    case "$item" in
      ctrl-t | ctrl-r | alt-c | completion) ;;
      "")
        ;;
      *)
        echo "install: unsupported shell binding: $item" >&2
        echo "install: expected ask, all, none, or a comma-separated list of ctrl-t, ctrl-r, alt-c, completion" >&2
        exit 2
        ;;
    esac
    IFS=','
  done
  IFS="$old_ifs"
}

ask_yes_no() {
  prompt="$1"
  default="$2"
  if [ "$default" = "yes" ]; then
    suffix="Y/n"
  else
    suffix="y/N"
  fi

  while :; do
    printf '%s [%s]: ' "$prompt" "$suffix" >/dev/tty
    IFS= read -r answer </dev/tty || answer=""
    answer="${answer:-$default}"
    case "$answer" in
      y | Y | yes | YES | Yes) return 0 ;;
      n | N | no | NO | No) return 1 ;;
      *) printf 'Please enter yes or no.\n' >/dev/tty ;;
    esac
  done
}

prompt_bindings() {
  validate_bindings "$bindings"
  if [ "$bindings" != "ask" ]; then
    printf '%s' "$bindings"
    return
  fi

  if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    printf 'all'
    return
  fi

  while :; do
    printf 'Choose Yuru shell bindings [all/custom/none] (all): ' >/dev/tty
    IFS= read -r answer </dev/tty || answer=""
    answer="${answer:-all}"
    case "$answer" in
      all | none)
        printf '%s' "$answer"
        return
        ;;
      custom)
        selected=""
        if ask_yes_no 'Enable CTRL-T file search?' yes; then selected="${selected:+$selected,}ctrl-t"; fi
        if ask_yes_no 'Enable CTRL-R history search?' yes; then selected="${selected:+$selected,}ctrl-r"; fi
        if ask_yes_no 'Enable ALT-C directory jump?' yes; then selected="${selected:+$selected,}alt-c"; fi
        if ask_yes_no 'Enable **<TAB> path completion?' yes; then selected="${selected:+$selected,}completion"; fi
        printf '%s' "${selected:-none}"
        return
        ;;
      ctrl-t | ctrl-r | alt-c | completion | *,*)
        validate_bindings "$answer"
        printf '%s' "$answer"
        return
        ;;
      *)
        printf 'Please enter all, custom, none, or a comma-separated binding list.\n' >/dev/tty
        ;;
    esac
  done
}

prompt_default_lang() {
  if [ "$default_lang" != "ask" ]; then
    printf '%s' "$default_lang"
    return
  fi

  if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    printf 'ja'
    return
  fi

  while :; do
    printf 'Choose Yuru default language [plain/ja/zh/auto/none] (ja): ' >/dev/tty
    IFS= read -r answer </dev/tty || answer=""
    answer="${answer:-ja}"
    case "$answer" in
      plain | ja | zh | auto | none)
        printf '%s' "$answer"
        return
        ;;
      *)
        printf 'Please enter plain, ja, zh, auto, or none.\n' >/dev/tty
        ;;
    esac
  done
}

install_config() {
  config_bindings="${1:-}"
  [ "$no_config" = "0" ] || {
    log "skipping user config"
    return
  }

  selected_lang="$(prompt_default_lang)"
  validate_default_lang "$selected_lang"
  ctrl_t_command="__yuru_compgen_path__ ."
  ctrl_t_opts="--preview 'file {}'"
  alt_c_command="__yuru_compgen_dir__ ."
  alt_c_opts="--preview 'ls -la {} 2>/dev/null | head -100'"
  file="$(config_file)"
  mkdir -p "$(dirname "$file")"
  tmp="$file.tmp.$$"

  if [ -f "$file" ]; then
    awk -v selected="$selected_lang" -v bindings="$config_bindings" -v ctrl_t_command="$ctrl_t_command" -v ctrl_t="$ctrl_t_opts" -v alt_c_command="$alt_c_command" -v alt_c="$alt_c_opts" '
      BEGIN {
        in_defaults = 0; saw_defaults = 0; wrote_lang = 0
        in_shell = 0; saw_shell = 0; wrote_shell = 0
      }
      function write_lang() {
        if (selected != "none" && wrote_lang == 0) {
          printf "lang = \"%s\"\n", selected
          wrote_lang = 1
        }
      }
      function write_shell_defaults() {
        if (bindings != "" && wrote_shell == 0) {
          printf "bindings = \"%s\"\n", bindings
          printf "ctrl_t_command = \"%s\"\n", ctrl_t_command
          printf "ctrl_t_opts = \"%s\"\n", ctrl_t
          printf "alt_c_command = \"%s\"\n", alt_c_command
          printf "alt_c_opts = \"%s\"\n", alt_c
          wrote_shell = 1
        }
      }
      /^[[:space:]]*\[defaults\][[:space:]]*$/ {
        print
        in_defaults = 1
        in_shell = 0
        saw_defaults = 1
        write_lang()
        next
      }
      /^[[:space:]]*\[shell\][[:space:]]*$/ {
        print
        in_defaults = 0
        in_shell = 1
        saw_shell = 1
        write_shell_defaults()
        next
      }
      /^[[:space:]]*\[/ {
        in_defaults = 0
        in_shell = 0
        print
        next
      }
      in_defaults && /^[[:space:]]*lang[[:space:]]*=/ { next }
      bindings != "" && in_shell && /^[[:space:]]*bindings[[:space:]]*=/ { next }
      bindings != "" && in_shell && /^[[:space:]]*ctrl_t_command[[:space:]]*=/ { next }
      bindings != "" && in_shell && /^[[:space:]]*ctrl_t_opts[[:space:]]*=/ { next }
      bindings != "" && in_shell && /^[[:space:]]*alt_c_command[[:space:]]*=/ { next }
      bindings != "" && in_shell && /^[[:space:]]*alt_c_opts[[:space:]]*=/ { next }
      { print }
      END {
        if (saw_defaults == 0) {
          print ""
          print "[defaults]"
          write_lang()
          print "load_fzf_defaults = \"safe\""
          print "fzf_compat = \"warn\""
        }
        if (bindings != "" && saw_shell == 0) {
          print ""
          print "[shell]"
          write_shell_defaults()
        }
      }
    ' "$file" >"$tmp"
  else
    {
      printf '[defaults]\n'
      if [ "$selected_lang" != "none" ]; then
        printf 'lang = "%s"\n' "$selected_lang"
      fi
      printf 'load_fzf_defaults = "safe"\n'
      printf 'fzf_compat = "warn"\n'
      if [ -n "$config_bindings" ]; then
        printf '\n[shell]\n'
        printf 'bindings = "%s"\n' "$config_bindings"
        printf 'ctrl_t_command = "%s"\n' "$ctrl_t_command"
        printf 'ctrl_t_opts = "%s"\n' "$ctrl_t_opts"
        printf 'alt_c_command = "%s"\n' "$alt_c_command"
        printf 'alt_c_opts = "%s"\n' "$alt_c_opts"
      fi
    } >"$tmp"
  fi

  mv "$tmp" "$file"
  if [ "$selected_lang" = "none" ]; then
    log "left default language unset in $file"
  else
    log "configured default language '$selected_lang' in $file"
  fi
  if [ -n "$config_bindings" ]; then
    log "configured shell bindings '$config_bindings' in $file"
  fi
}

detect_target() {
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m | tr '[:upper:]' '[:lower:]')"

  case "$os" in
    darwin)
      case "$arch" in
        arm64 | aarch64) printf 'aarch64-apple-darwin' ;;
        x86_64 | amd64) printf 'x86_64-apple-darwin' ;;
        *) echo "install: unsupported macOS architecture: $arch" >&2; exit 1 ;;
      esac
      ;;
    linux)
      case "$arch" in
        x86_64 | amd64) printf 'x86_64-unknown-linux-gnu' ;;
        *) echo "install: unsupported Linux architecture: $arch" >&2; exit 1 ;;
      esac
      ;;
    msys* | mingw* | cygwin*)
      case "$arch" in
        x86_64 | amd64) printf 'x86_64-pc-windows-msvc' ;;
        *) echo "install: unsupported Windows architecture: $arch" >&2; exit 1 ;;
      esac
      ;;
    *)
      echo "install: unsupported OS: $os" >&2
      exit 1
      ;;
  esac
}

download() {
  url="$1"
  out="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fL --retry 3 --retry-delay 2 -o "$out" "$url"
  elif command -v wget >/dev/null 2>&1; then
    wget -O "$out" "$url"
  else
    echo "install: curl or wget is required to download releases" >&2
    exit 1
  fi
}

verify_asset_checksum() {
  asset="$1"
  base_url="$2"
  sums_url="$base_url/SHA256SUMS"
  sums_file="$tmp/SHA256SUMS"

  log "downloading SHA256SUMS"
  download "$sums_url" "$sums_file"
  expected="$(
    awk -v asset="$asset" '
      $2 == asset || $2 == "*" asset { print $1; found = 1; exit }
      END { if (!found) exit 1 }
    ' "$sums_file"
  )" || {
    echo "install: SHA256SUMS did not contain $asset" >&2
    exit 1
  }

  if command -v sha256sum >/dev/null 2>&1; then
    actual="$(sha256sum "$tmp/$asset" | awk '{print $1}')"
  elif command -v shasum >/dev/null 2>&1; then
    actual="$(shasum -a 256 "$tmp/$asset" | awk '{print $1}')"
  else
    echo "install: sha256sum or shasum is required to verify release assets" >&2
    exit 1
  fi

  if [ "$actual" != "$expected" ]; then
    echo "install: checksum mismatch for $asset" >&2
    echo "install: expected $expected" >&2
    echo "install: actual   $actual" >&2
    exit 1
  fi
  log "verified $asset checksum"
}

install_from_source() {
  need cargo
  log "building release binary with cargo"
  cargo build --release -p yuru
  mkdir -p "$bin_dir"
  cp target/release/yuru "$bin_dir/yuru"
  chmod 755 "$bin_dir/yuru"
}

install_from_release() {
  target="$(detect_target)"
  case "$target" in
    *windows*) asset="yuru-$target.zip" ;;
    *) asset="yuru-$target.tar.gz" ;;
  esac

  if [ "$version" = "latest" ]; then
    base_url="https://github.com/$repo/releases/latest/download"
  else
    base_url="https://github.com/$repo/releases/download/$version"
  fi
  url="$base_url/$asset"

  tmp="$(mktemp -d "${TMPDIR:-/tmp}/yuru-install.XXXXXX")"
  trap 'rm -rf "$tmp"' EXIT INT TERM

  log "downloading $asset"
  download "$url" "$tmp/$asset"
  verify_asset_checksum "$asset" "$base_url"

  case "$asset" in
    *.zip)
      need unzip
      unzip -q "$tmp/$asset" -d "$tmp"
      binary="$tmp/yuru.exe"
      ;;
    *.tar.gz)
      tar -xzf "$tmp/$asset" -C "$tmp"
      binary="$tmp/yuru"
      ;;
  esac

  if [ ! -f "$binary" ]; then
    echo "install: archive did not contain yuru binary" >&2
    exit 1
  fi

  mkdir -p "$bin_dir"
  cp "$binary" "$bin_dir/$(basename "$binary")"
  chmod 755 "$bin_dir/$(basename "$binary")"
}

shell_block() {
  shell_name="$1"
  yuru_bin="$bin_dir/yuru"
  quoted_bin="$(sh_quote "$yuru_bin")"
  quoted_dir="$(sh_quote "$bin_dir")"
  case "$shell_name" in
    bash)
      cat <<EOF

# yuru shell integration
export YURU_BIN=$quoted_bin
export YURU_BIN_DIR=$quoted_dir
case ":\$PATH:" in
  *":\$YURU_BIN_DIR:"*) ;;
  *) export PATH="\$YURU_BIN_DIR:\$PATH" ;;
esac
if [ -x "\$YURU_BIN" ]; then
  eval "\$("\$YURU_BIN" --bash)"
fi
EOF
      ;;
    zsh)
      cat <<EOF

# yuru shell integration
export YURU_BIN=$quoted_bin
export YURU_BIN_DIR=$quoted_dir
case ":\$PATH:" in
  *":\$YURU_BIN_DIR:"*) ;;
  *) export PATH="\$YURU_BIN_DIR:\$PATH" ;;
esac
if [ -x "\$YURU_BIN" ]; then
  source <("\$YURU_BIN" --zsh)
fi
EOF
      ;;
    fish)
      fish_bin="$(fish_quote "$yuru_bin")"
      fish_dir="$(fish_quote "$bin_dir")"
      cat <<EOF

# yuru shell integration
set -gx YURU_BIN $fish_bin
if not contains -- $fish_dir \$PATH
  set -gx PATH $fish_dir \$PATH
end
if test -x "\$YURU_BIN"
  "\$YURU_BIN" --fish | source
end
EOF
      ;;
  esac
}

append_once() {
  file="$1"
  marker="$2"
  content="$3"
  mkdir -p "$(dirname "$file")"
  touch "$file"
  if grep -F "$marker" "$file" >/dev/null 2>&1; then
    log "shell integration already present in $file"
    return
  fi
  printf '%s\n' "$content" >>"$file"
  log "updated $file"
}

current_shell() {
  name="$(basename "${SHELL:-}")"
  case "$name" in
    bash | zsh | fish) printf '%s' "$name" ;;
    *) printf '' ;;
  esac
}

install_shell() {
  selected="$1"
  if [ "$selected" = "current" ]; then
    selected="$(current_shell)"
    if [ -z "$selected" ]; then
      log "could not detect bash, zsh, or fish; skipping shell integration"
      return
    fi
  elif [ "$selected" = "all" ]; then
    selected="bash,zsh,fish"
  fi

  old_ifs="$IFS"
  IFS=','
  for shell_name in $selected; do
    IFS="$old_ifs"
    shell_name="$(printf '%s' "$shell_name" | tr -d '[:space:]')"
    case "$shell_name" in
      bash)
        append_once "$HOME/.bashrc" "yuru shell integration" "$(shell_block bash)"
        ;;
      zsh)
        append_once "$HOME/.zshrc" "yuru shell integration" "$(shell_block zsh)"
        ;;
      fish)
        append_once "$HOME/.config/fish/config.fish" "yuru shell integration" "$(shell_block fish)"
        ;;
      "")
        ;;
      *)
        echo "install: unsupported shell for Unix installer: $shell_name" >&2
        exit 2
        ;;
    esac
    IFS=','
  done
  IFS="$old_ifs"
}

if [ "$from_source" = "1" ]; then
  install_from_source
else
  install_from_release
fi

log "installed binary into $bin_dir"
validate_default_lang "$default_lang"
validate_bindings "$bindings"
if [ -n "$shells" ] || [ "$bindings" != "ask" ]; then
  selected_bindings="$(prompt_bindings)"
fi
install_config "$selected_bindings"

case ":$PATH:" in
  *":$bin_dir:"*) ;;
  *) log "add $bin_dir to PATH if yuru is not found by your shell" ;;
esac

if [ -n "$shells" ]; then
  install_shell "$shells"
  log "restart your shell or reload your shell config"
fi
